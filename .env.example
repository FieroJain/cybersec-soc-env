# CyberSec-SOC-OpenEnv Environment Variables
# Copy this file to .env and fill in your values

# LLM API endpoint (HuggingFace Inference API or compatible)
API_BASE_URL = os.environ.get("API_BASE_URL", "https://router.huggingface.co/v1")

# Model to use for inference
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Your Hugging Face token (get from huggingface.co/settings/tokens)
HF_TOKEN=your_hf_token_here

# URL where the SOC environment server is running
ENV_URL=http://localhost:8000
